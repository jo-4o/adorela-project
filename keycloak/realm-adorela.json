{
  "id": "adorela",
  "realm": "adorela",
  "enabled": true,
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin" }],
      "realmRoles": ["admin"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin" }
    ]
  },
  "clients": [
    {
      "clientId": "adorela-web",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:4200/*", "http://localhost/*", "*"],
      "webOrigins": ["http://localhost:4200", "http://localhost", "*"],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "usermodel.realmRoleMapping.rolePrefix": "",
            "multivalued": "true",
            "claims.as.array": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles"
          }
        }
      ]
    }
  ]
}
