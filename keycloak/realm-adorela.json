{
  "id": "adorela",
  "realm": "adorela",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "dono",
        "description": "Proprietário do sistema. Acesso total: criar, editar, excluir e revisar todos os recursos."
      },
      {
        "name": "gerente",
        "description": "Gerente da loja. Pode criar e editar produtos e categorias, mas não pode excluir."
      },
      {
        "name": "revisao",
        "description": "Perfil de revisão/leitura. Pode visualizar todos os recursos, mas não pode modificar."
      }
    ]
  },
  "clients": [
    {
      "clientId": "adorela-web",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost/*",
        "http://e-instancia.net/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost",
        "http://e-instancia.net"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "usermodel.realmRoleMapping.rolePrefix": "",
            "multivalued": "true",
            "claims.as.array": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles"
          }
        }
      ]
    }
  ]
}
