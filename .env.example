# =====================================================================
# Adorela - Variáveis de ambiente para deploy em 3 VMs
# Copie este arquivo para .env e ajuste os valores para cada VM
#
# VM 1: PostgreSQL + Keycloak
# VM 2: Backend API (Spring Boot)
# VM 3: Frontend Web (Angular + Nginx)
# =====================================================================

# ---------- IPs/Hostnames das VMs ----------
# Substitua pelos IPs ou hostnames reais das suas VMs
VM1_HOST=192.168.1.10
API_HOST=192.168.1.11
WEB_HOST=192.168.1.12

# ---------- PostgreSQL (VM 1) ----------
POSTGRES_DB=adorela
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA

# ---------- Keycloak (VM 1) ----------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=TROQUE_ESTA_SENHA
# URL pública do Keycloak (como o browser do usuário vai acessar)
KEYCLOAK_PUBLIC_URL=http://192.168.1.10:8080

# ---------- Backend API (VM 2) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://192.168.1.10:5432/adorela
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=TROQUE_ESTA_SENHA
# Issuer URI deve ser a URL PÚBLICA do Keycloak (mesma que o browser usa)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://192.168.1.10:8080/realms/adorela
# CORS - URL do frontend (sem barra no final)
ADORELA_CORS_ALLOWED_ORIGINS=http://192.168.1.12
# Diretório de uploads
ADORELA_UPLOAD_DIR=/app/uploads

# ---------- Frontend Angular / Nginx (VM 3) ----------
# URL da API para o proxy reverso do Nginx (IP da VM 2)
API_PORT=8080
# URL pública do Keycloak (browser do usuário)
KEYCLOAK_URL=http://192.168.1.10:8080
KEYCLOAK_REALM=adorela
KEYCLOAK_CLIENT_ID=adorela-web
