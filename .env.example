# =====================================================================
# Adorela - Variáveis de ambiente para deploy em 3 VMs
# Copie este arquivo para .env e troque os IPs das VMs
#
# VM 1: PostgreSQL + Keycloak
# VM 2: Backend API (Spring Boot)
# VM 3: Frontend Web (Angular + Nginx)
# =====================================================================

# ---------- IPs/Hostnames das VMs ----------
# Substitua pelos IPs reais das suas VMs
VM1_HOST=192.168.1.10
API_HOST=192.168.1.11
WEB_HOST=192.168.1.12

# ---------- PostgreSQL (VM 1) ----------
POSTGRES_DB=adorela
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

# ---------- Keycloak (VM 1) ----------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---------- Backend API (VM 2) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://192.168.1.10:5432/adorela
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=123456
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://192.168.1.10:8080/realms/adorela
ADORELA_CORS_ALLOWED_ORIGINS=http://192.168.1.12
ADORELA_UPLOAD_DIR=/app/uploads

# ---------- Frontend Angular / Nginx (VM 3) ----------
API_PORT=8080
KEYCLOAK_URL=http://192.168.1.10:8080
KEYCLOAK_REALM=adorela
KEYCLOAK_CLIENT_ID=adorela-web
